  server.send(200,"text/plain; charset=utf-8", pumpState ? "ON" : "OFF");
}
void handlePumpState(){ server.send(200,"text/plain; charset=utf-8", pumpState ? "ON" : "OFF"); }

// ---------------- AUTOPUMP ROUTES ----------------
void handleAutoPumpToggle() {
  autoPumpEnabled = !autoPumpEnabled;
  // reset last trigger guard when toggling (so schedule triggers cleanly after re-enable)
  if (!autoPumpEnabled) lastTriggerMinute = -1;
  server.send(200, "text/plain; charset=utf-8", autoPumpEnabled ? "ON" : "OFF");
}
void handleAutoPumpState() {
  server.send(200, "text/plain; charset=utf-8", autoPumpEnabled ? "ON" : "OFF");
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(115200);
  pinMode(pumpPin,OUTPUT);
  digitalWrite(pumpPin,LOW);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  WiFi.begin(ssid,password);
  while(WiFi.status()!=WL_CONNECTED){ delay(500); Serial.print("."); }

  Serial.println("\nWiFi connected");
  Serial.println(WiFi.localIP());

  configTime(gmtOffset_sec,daylightOffset_sec,ntpServer);
  updateWeather(); // boot fetch

  server.on("/",handleRoot);
  server.on("/weather",handleWeather);
  server.on("/time",handleTime);
  server.on("/nextPump",handleNextPump);
  server.on("/info", handleInfo);
  server.on("/pump/toggle",handlePumpToggle);
  server.on("/pump/state",handlePumpState);
  server.on("/tank",handleWaterLevel);
  server.on("/pump/info", handlePumpInfo);

  // autopump endpoints
  server.on("/autopump/toggle", handleAutoPumpToggle);
  server.on("/autopump/state", handleAutoPumpState);

   dht.begin();
  analogReadResolution(12);
  updateSensors(); 

  server.begin();
}

// ---------------- LOOP ----------------
void loop() {
  server.handleClient();
  handleAutoPumpSchedule();
  handleWeatherSchedule();

    // periodic sensor update
  if (millis() - lastSensorMillis >= sensorInterval) {
    lastSensorMillis = millis();
    updateSensors();
}

 float distance = getDistanceCM();

  Serial.print("Distance: ");
  Serial.print(distance);
  Serial.println(" cm");
}

