// ---------------- Ultrasonic sensor control ----------------
long readOnce() {
  // Ensure clean trigger
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(5);

  // JSN-SR04T likes a slightly longer trigger
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(20);
  digitalWrite(TRIG_PIN, LOW);

  // Read echo with timeout (40ms ≈ ~6.8m max)
  long duration = pulseIn(ECHO_PIN, HIGH, 40000);

  if (duration == 0) return -1; // no echo

  return duration;
}

float getDistanceCM() {
  const int samples = 5;
  long vals[samples];
  int count = 0;

  for (int i = 0; i < samples; i++) {
    long d = readOnce();
    if (d > 0) {
      vals[count++] = d;
    }
    delay(50);
  }

  if (count == 0) return -1;

  // Simple average (or we can do median if you want)
  long sum = 0;
  for (int i = 0; i < count; i++) sum += vals[i];
  long avg = sum / count;

  // Speed of sound ≈ 343 m/s = 0.0343 cm/us
  float distance = (avg * 0.0343) / 2.0;
  return distance;
}

//------------------ TANK STATUS ----------------

String getTankStatus() {
  float d = getDistanceCM();

  if (d < 0) return "Error";

  if (d <= 15) {
    return "Full";
  } 
  else if (d >= 16 && d <= 29) {
    return "50%";
  } 
  else {
    return "Empty";
  }
}

