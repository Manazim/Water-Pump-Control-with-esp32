// ---------------- WEATHER MAPPING ----------------
String mapWeatherBM(String main) {
  if (main == "Clear") return "Cerah";
  if (main == "Clouds") return "Berawan";
  if (main == "Rain") return "Hujan";
  if (main == "Drizzle") return "Hujan Renyai";
  if (main == "Thunderstorm") return "Ribut Petir";
  if (main == "Mist" || main == "Fog") return "Berkabus";
  if (main == "Haze") return "Jerebu";
  return main;
}

// ---------------- WEATHER FETCH ----------------
void updateWeather() {
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;
  http.begin(weatherUrl);
  int httpCode = http.GET();

  if (httpCode == 200) {
    String payload = http.getString();
    StaticJsonDocument<2048> doc;
    DeserializationError err = deserializeJson(doc, payload);

    if (!err) {
      // main weather
      String weatherEN = doc["weather"][0]["main"].as<String>();
      weatherMain = mapWeatherBM(weatherEN);

      // wind speed (m/s)
      double ws = doc["wind"]["speed"] | 0.0;
      windSpeed = (float)ws;

      Serial.println("🌦 Weather updated: " + weatherMain);
      Serial.printf("  Kelajuan angin: %.2f m/s\n", windSpeed);
    } else {
      Serial.println("JSON parse error in updateWeather()");
    }
  } else {
    Serial.printf("HTTP error: %d\n", httpCode);
  }
  http.end();
}

// ---------------- TIME STRING ----------------
String getTimeString() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return "Time error";
  char buf[32];
  strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", &timeinfo);
  return String(buf);
}

// ---------------- NEXT PUMP TIME ----------------
String getNextPumpTime() {
  if (!autoPumpEnabled) return "-----"; // show dashes when auto disabled

  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return "--:--";

  int h = timeinfo.tm_hour;
  int nextHour;

  if (h < schedule1Hour) nextHour = schedule1Hour;
  else if (h < schedule2Hour) nextHour = schedule2Hour;
  else nextHour = schedule1Hour; // next day

  char buf[6];
  sprintf(buf, "%02d:00", nextHour);
  return String(buf);
}

// ---------------- AUTO PUMP ----------------
void handleAutoPumpSchedule() {
  // Respect user master switch
  if (!autoPumpEnabled) {
    // reset guard so schedule can trigger correctly after re-enable
    lastTriggerMinute = -1;
    return;
  }

  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int h = timeinfo.tm_hour;
  int m = timeinfo.tm_min;

  if ((h == schedule1Hour || h == schedule2Hour) && m == 0) {
    if (lastTriggerMinute != m) {

      // Decide duration based on current temperature
      if (tempC > 35.0) {
        pumpRunDuration = 120000; // 2 minutes
        Serial.println("🔥 High temperature detected (>35°C), pump for 2 minutes");
      } else {
        pumpRunDuration = 60000;  // default 1 minute
        Serial.println("🌤 Normal temperature, pump for 1 minute");
      }

      pumpState = true;
      autoPumpActive = true;
      pumpStartMillis = millis();
      digitalWrite(pumpPin, HIGH);
      lastTriggerMinute = m;
      Serial.println("⏰ Auto pump ON");
    }
  }

  if (autoPumpActive && millis() - pumpStartMillis >= pumpRunDuration) {
    pumpState = false;
    autoPumpActive = false;
    digitalWrite(pumpPin, LOW);
    Serial.println("⏹ Auto pump OFF");
  }

  if (m != lastTriggerMinute) lastTriggerMinute = -1;
}

// ---------------- WEATHER SCHEDULE ----------------
void handleWeatherSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int hour = timeinfo.tm_hour;
  int minute = timeinfo.tm_min;

  // trigger at top of the hour and only once per hour
  if (minute == 0 && hour != lastWeatherFetchHour) {
    updateWeather();
    lastWeatherFetchHour = hour;
    Serial.printf("Scheduled hourly weather fetch at %02d:00\n", hour);
  }
}

// ------------------- SENSOR UPDATE ----------------
void updateSensors() {
  mq135_raw = analogRead(MQ135_PIN);

  airIndex = map(mq135_raw, AIR_CLEAN, AIR_BAD, 0, 100);
  airIndex = constrain(airIndex, 0, 100);

  if (airIndex <= 50) {
  airQuality = "GOOD";
}
else if (airIndex >= 51 && airIndex <= 100) {
  airQuality = "MODERATE";
}
else if (airIndex >= 101 && airIndex <= 300) {
  airQuality = "BAD";
}
else {
  airQuality = "VERY BAD";
}


  float h = dht.readHumidity();
  float t = dht.readTemperature();

  if (!isnan(h) && !isnan(t)) {
    humiditySensor = (int)h;
    tempC = t;
  }
}


